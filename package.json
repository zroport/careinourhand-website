{
  "name": "careinhandwebsite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npx prisma generate && NODE_OPTIONS='--max-old-space-size=2048' next build --webpack",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "db:seed": "npx tsx prisma/seed.ts",
    "seed:admin": "npx tsx prisma/seed-admin.ts",
    "create:admin": "node scripts/create-admin.js",
    "seed:services": "node scripts/seed-services.js",
    "seed:faqs": "node scripts/seed-faqs.js",
    "seed:settings": "node scripts/seed-settings.js",
    "seed:pages": "npx tsx prisma/seed-pages.ts",
    "seed:all": "npm run create:admin && npm run seed:services && npm run seed:faqs && npm run seed:settings && npm run seed:pages",
    "postinstall": "node scripts/patch-next.js"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "resend": "^6.12.2",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
}