// prisma/schema.prisma
// Care In Our Hand - NDIS Provider Website Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTHENTICATION (NextAuth.js)
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  role          UserRole  @default(ADMIN)
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  ADMIN
  EDITOR
}

// ============================================
// SERVICES
// ============================================

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  description String
  icon        String?
  image       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// REFERRALS (Support Coordinators)
// ============================================

model Referral {
  id                String          @id @default(cuid())
  participantName   String
  participantPhone  String?
  participantEmail  String?
  ndisNumber        String?
  managementType    ManagementType?
  coordinatorName   String?
  coordinatorOrg    String?
  coordinatorPhone  String?
  coordinatorEmail  String?
  servicesNeeded    String?
  additionalNotes   String?
  status            ReferralStatus  @default(NEW)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

enum ManagementType {
  SELF_MANAGED
  PLAN_MANAGED
  NDIA_MANAGED
}

enum ReferralStatus {
  NEW
  IN_REVIEW
  CONTACTED
  ACCEPTED
  DECLINED
}

// ============================================
// BOOKINGS (Direct Clients)
// ============================================

model Booking {
  id            String        @id @default(cuid())
  fullName      String
  email         String
  phone         String
  address       String?
  serviceType   String
  preferredDate DateTime
  preferredTime String
  notes         String?
  status        BookingStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ============================================
// CONTACT FORM (General Inquiries)
// ============================================

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============================================
// FEEDBACK & COMPLAINTS (NDIS Requirement)
// ============================================

model Feedback {
  id          String       @id @default(cuid())
  name        String?
  email       String?
  phone       String?
  type        FeedbackType
  message     String
  isAnonymous Boolean      @default(false)
  status      FeedbackStatus @default(RECEIVED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum FeedbackType {
  COMPLIMENT
  SUGGESTION
  COMPLAINT
}

enum FeedbackStatus {
  RECEIVED
  INVESTIGATING
  RESOLVED
}

// ============================================
// BLOG / NEWS
// ============================================

model BlogPost {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  excerpt     String?
  content     String
  coverImage  String?
  author      String      @default("Care In Our Hand")
  isPublished Boolean     @default(false)
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ============================================
// FAQ
// ============================================

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// CAREERS / JOB LISTINGS
// ============================================

model JobListing {
  id           String   @id @default(cuid())
  title        String
  location     String   @default("Leppington, NSW")
  type         String   @default("Full-time")
  description  String
  requirements String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model JobApplication {
  id         String   @id @default(cuid())
  jobId      String?
  fullName   String
  email      String
  phone      String
  resume     String?
  coverNote  String?
  createdAt  DateTime @default(now())
}

// ============================================
// MEDIA LIBRARY
// ============================================

model Media {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int?
  altText   String?
  createdAt DateTime @default(now())
}

// ============================================
// SITE SETTINGS (Admin-editable)
// ============================================

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ============================================
// TESTIMONIALS
// ============================================

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}